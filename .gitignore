.ai-code-tracker.json
.vscode/

# Build outputs — defensive catch-all at repo root. Each subproject
# (slopsmith/, slopsmith-desktop/, slopsmithRust/) already ignores its own
# build artifacts; these entries keep the root safe if anyone runs a build
# here directly. No build artifacts are tracked today, so this changes
# nothing that's committed.
build/
dist/
release/
target/
*.node

# Backups / temp (e.g. build-macos.sh NO_NOTARIZE leaves package.json.bak.nota
# if killed mid-build; *.bak* keeps them out of the tree)
*.bak
*.bak.*

# Logs
*.log

# Temp workdirs
.tmp/

# OS
.DS_Store
